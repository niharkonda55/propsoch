# ============================================
# DATABASE CONFIGURATION
# ============================================

# Database dialect: 'sqlite', 'mysql', 'postgres'
DB_DIALECT=sqlite

# For SQLite: path to database file
# For MySQL/Postgres: omit this line
DB_STORAGE=./database.sqlite

# For MySQL/Postgres only:
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=splitwise_mvp

# ============================================
# SERVER CONFIGURATION
# ============================================

# Environment: 'development', 'test', 'production'
NODE_ENV=development

# Server port
PORT=3000

# ============================================
# AUTHENTICATION (Optional - for future use)
# ============================================

# JWT Secret - Use a strong random string in production
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# JWT Token expiration time (e.g., '7d', '24h', '1h')
JWT_EXPIRATION=7d

# ============================================
# EMAIL CONFIGURATION
# ============================================

# SMTP Server details
MAIL_HOST=smtp.example.com
MAIL_PORT=587

# Email credentials
MAIL_USER=your_email@example.com
MAIL_PASSWORD=your_password

# From address for emails
MAIL_FROM=noreply@splitwise.com

# ============================================
# COMMON CONFIGURATIONS
# ============================================

# SQLite Setup (Development)
# Copy the lines below (no changes needed):
# DB_DIALECT=sqlite
# DB_STORAGE=./database.sqlite

# MySQL Setup (Production)
# Replace with your MySQL configuration:
# DB_DIALECT=mysql
# DB_HOST=your-mysql-host.com
# DB_USER=your_username
# DB_PASSWORD=your_password
# DB_NAME=splitwise_mvp

# Gmail SMTP Setup
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USER=your-email@gmail.com
# MAIL_PASSWORD=your-app-specific-password
# (Generate app-specific password in Gmail Security settings)
